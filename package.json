{
  "name": "ai-agent-prompt-injection-guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build eval/history-replay.ts eval/capture-server.ts src/adapters/proxy/cliproxy.ts src/adapters/proxy/cliproxy-entry.ts src/adapters/codex/cli.ts src/adapters/claude/cli.ts src/adapters/opencode/plugin.ts --outdir dist --target bun --format esm",
    "build:cliproxy-plugin": "bun run scripts/build-cliproxy-plugin.ts",
    "cliproxy:doctor": "bun run scripts/aipig-cliproxy.ts doctor",
    "cliproxy:install": "bun run scripts/aipig-cliproxy.ts install",
    "eval:real-chain": "bun run scripts/real-chain-eval.ts",
    "test": "bun test",
    "verify": "bun test && bun run build"
  },
  "dependencies": {
    "jsonc-parser": "3.3.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "bun-types": "1.3.14",
    "typescript": "6.0.3"
  }
}
